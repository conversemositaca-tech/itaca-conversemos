# Copia este archivo a .env y completa los valores reales.
# .env está en .gitignore — nunca se sube al repo.

# Django
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-larga-y-secreta
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (desarrollo local)
DB_NAME=clinica_db
DB_USER=clinica_user
DB_PASSWORD=tu_password
DB_HOST=localhost
DB_PORT=5432

# --- Producción (nube). NO se usan en local. Ver DEPLOY.md ---
# DATABASE_URL la inyecta el proveedor (Railway/Render) al agregar PostgreSQL.
# DATABASE_URL=postgres://usuario:clave@host:5432/basedatos
# En producción: DJANGO_DEBUG=False, y DJANGO_ALLOWED_HOSTS con tu dominio.
# DJANGO_CSRF_ORIGINS=https://tu-dominio (con esquema, coma-separado)
# DJANGO_MEDIA_ROOT=/data  (carpeta de un VOLUMEN persistente para los adjuntos)

# WhatsApp (Evolution API en EasyPanel)
EVOLUTION_API_URL=https://tu-evolution.easypanel.host
EVOLUTION_API_KEY=tu_api_key
EVOLUTION_INSTANCE=nombre_de_tu_instancia
WHATSAPP_PAIS_PREFIJO=51

# Google Calendar (opcional) — sincroniza las citas con un service account.
# Si se deja vacío, la sincronización queda apagada (no-op).
#   1) Crea un service account en Google Cloud con la Calendar API activada.
#   2) Comparte cada calendario con el email del service account (permiso editor).
#   3) Pega aquí el JSON (o la ruta al archivo) y el ID de cada calendario por sede.
# GOOGLE_CALENDAR_CREDENTIALS=/ruta/al/service-account.json
# GOOGLE_CALENDAR_LIMA=xxxxx@group.calendar.google.com
# GOOGLE_CALENDAR_PIURA=yyyyy@group.calendar.google.com
# GOOGLE_CALENDAR_ID=calendario-de-respaldo@group.calendar.google.com

# Transcripción de notas con Whisper (local; gratis). El modelo se descarga solo
# la primera vez. Tamaños: tiny|base|small|medium (más grande = mejor pero más lento).
# WHISPER_MODEL=small
# WHISPER_DEVICE=cpu
# Estructurar la transcripción en campos (opcional): si pones la clave de OpenAI
# (la misma del bot Eli sirve), la IA separa la nota en motivo/diagnóstico/indicaciones/
# evolución. Sin esto, la transcripción cae en la nota y el terapeuta la edita.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
